# Optional until your Reddit Data API access is approved.
# If unset, the Reddit scan is skipped and only GitHub is scanned.
REDDIT_CLIENT_ID=your_id_here
REDDIT_CLIENT_SECRET=your_secret_here

ANTHROPIC_API_KEY=sk-ant-...

# Optional: raises GitHub's search API rate limit from 10 to 30 requests/min.
# A token with no scopes (public repo read access) is enough.
GITHUB_TOKEN=your_github_token_here

# Optional: enable the Civitai scanner. Civitai region-blocks some countries
# (e.g. South Korea, HTTP 451 REGION_BLOCKED), so it is off by default.
# It may work from CI runners in other regions - enabling is your call.
CIVITAI_ENABLED=false

# Optional: models for the two-tier analysis.
# Every candidate is screened with SCREEN_MODEL (cheap); only flagged or
# low-confidence items are re-checked with CONFIRM_MODEL (strong).
# Set both to the same model to disable the second pass.
SCREEN_MODEL=claude-haiku-4-5
CONFIRM_MODEL=claude-opus-4-8
